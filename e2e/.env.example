# BaseShop E2E Test Environment Variables
# Copy this file to .env and fill in the values

# Test user credentials
TEST_USER_EMAIL=cliente@test.com
TEST_USER_PASSWORD=your-test-user-password

# Test admin credentials
TEST_ADMIN_EMAIL=admin@baseshop.com
TEST_ADMIN_PASSWORD=your-admin-password

# PayU sandbox credentials
TEST_PAYU_API_KEY=your-payu-api-key
TEST_PAYU_MERCHANT_ID=your-payu-merchant-id

# Internal service-to-service secret
TEST_INTERNAL_SECRET=your-internal-service-secret
