# ============================================
# BaseShop — Variables de entorno para PRODUCCIÓN
# Copiar como .env o configurar en Railway/Cloud
# ============================================

# ── Compartidas (todos los servicios) ──────
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_DE_64_CHARS_MINIMO
NODE_ENV=production

# ── API Gateway (3000) ─────────────────────
AUTH_SERVICE_URL=https://baseshop-auth.up.railway.app
USERS_SERVICE_URL=https://baseshop-users.up.railway.app
PRODUCTS_SERVICE_URL=https://baseshop-products.up.railway.app
CART_SERVICE_URL=https://baseshop-cart.up.railway.app
ORDERS_SERVICE_URL=https://baseshop-orders.up.railway.app
PAYMENTS_SERVICE_URL=https://baseshop-payments.up.railway.app
REVIEWS_SERVICE_URL=https://baseshop-reviews.up.railway.app
FAVORITES_SERVICE_URL=https://baseshop-favorites.up.railway.app
ALLOWED_ORIGINS=https://tu-dominio-frontend.com,https://baseshop-web.up.railway.app

# ── Auth Service (3001) ───────────────────
JWT_EXPIRATION=24h
DB_PATH=./data/auth.db
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY_HERE
RECAPTCHA_THRESHOLD=0.5
ADMIN_EMAIL=admin@baseshop.com
ADMIN_PASSWORD=YOUR_SECURE_ADMIN_PASSWORD_HERE
SMTP_USER=YOUR_SMTP_EMAIL_HERE
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ── Users Service (3002) ──────────────────
DB_PATH=./data/users.db

# ── Products Service (3003) ───────────────
DB_PATH=./data/products.db

# ── Cart Service (3004) ───────────────────
DB_PATH=./data/cart.db

# ── Orders Service (3005) ─────────────────
DB_PATH=./data/orders.db

# ── Payments Service (3006) ───────────────
DB_PATH=./data/payments.db
PAYU_API_KEY=YOUR_PAYU_API_KEY_HERE
PAYU_API_LOGIN=YOUR_PAYU_API_LOGIN_HERE
PAYU_MERCHANT_ID=YOUR_PAYU_MERCHANT_ID_HERE
PAYU_ACCOUNT_ID=YOUR_PAYU_ACCOUNT_ID_HERE
PAYU_IS_TEST=false

# ── Reviews Service (3007) ────────────────
DB_PATH=./data/reviews.db

# ── Favorites Service (3008) ──────────────
DB_PATH=./data/favorites.db
