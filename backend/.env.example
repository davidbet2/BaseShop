# ============================================
# BaseShop — Docker Compose environment variables
# Copy this file as .env and fill in the values
# ============================================

# Shared
JWT_SECRET=CHANGE_ME_use_64_chars_minimum

# Auth Service
ADMIN_EMAIL=admin@baseshop.com
ADMIN_PASSWORD=CHANGE_ME_secure_password
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_V3_SECRET_KEY
ALLOWED_ORIGINS=http://localhost:9090,http://localhost:8080,http://localhost:3000

# Brevo (Email transaccional)
BREVO_API_KEY=YOUR_BREVO_API_KEY
BREVO_SENDER_EMAIL=shopbrevosmtp@gmail.com
BREVO_SENDER_NAME=BaseShop

# Payments Service (PayU)
PAYU_API_KEY=YOUR_PAYU_API_KEY
PAYU_API_LOGIN=YOUR_PAYU_API_LOGIN
PAYU_MERCHANT_ID=YOUR_PAYU_MERCHANT_ID
PAYU_ACCOUNT_ID=YOUR_PAYU_ACCOUNT_ID
PAYU_IS_TEST=true

# Frontend URL
FRONTEND_URL=http://localhost:8080
GATEWAY_URL=http://localhost:3000
