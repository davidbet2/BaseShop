# ============================================
# BaseShop — Environment Variables Template
# Copy this file as .env and fill in the values:
#   cp .env.example .env
# THIS FILE IS SAFE TO COMMIT (no secrets)
# ============================================

# ---- General ----
NODE_ENV=development

# ---- Shared (all services) ----
JWT_SECRET=CHANGE_ME_use_64_chars_minimum
JWT_EXPIRATION=24h

# ---- Auth Service ----
ADMIN_EMAIL=admin@baseshop.com
ADMIN_PASSWORD=CHANGE_ME_secure_password
RECAPTCHA_SECRET_KEY=
RECAPTCHA_THRESHOLD=0.5
MOBILE_APP_SECRET=
ALLOWED_ORIGINS=http://localhost:9090,http://localhost:8080,http://localhost:3000

# ---- Brevo SMTP (Email transaccional) ----
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SENDER_EMAIL=noreply@baseshop.dev
BREVO_SENDER_NAME=BaseShop

# ---- Payments Service (PayU) ----
# Para sandbox/test: usa las credenciales de prueba de PayU
# Docs: https://developers.payulatam.com/latam/es/docs/getting-started/test-your-solution.html
PAYU_API_KEY=YOUR_PAYU_API_KEY
PAYU_API_LOGIN=YOUR_PAYU_API_LOGIN
PAYU_MERCHANT_ID=YOUR_PAYU_MERCHANT_ID
PAYU_ACCOUNT_ID=YOUR_PAYU_ACCOUNT_ID
PAYU_IS_TEST=true

# ---- URLs ----
FRONTEND_URL=http://localhost:8080
GATEWAY_URL=http://localhost:3000

# ---- Internal Service Communication ----
INTERNAL_SERVICE_SECRET=CHANGE_ME_internal_secret
